#!@PYTHON@
import os
import sys
import signal
import gettext

VERSION = '@VERSION@'
pkgdatadir = '@PKGDATADIR@'
moduledir = '@MODULEDIR@'
localedir = '@LOCALEDIR@'

sys.path.insert(1, moduledir)
signal.signal(signal.SIGINT, signal.SIG_DFL)
gettext.install('shoebox', localedir)

if __name__ == '__main__':
    import gi
    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'shoebox.gresource'))
    resource._register()

    from shoebox import main
    sys.exit(main.run(VERSION))
